generator client {
  provider = "prisma-client"
  output   = "../prisma/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Usuario {
  id     Int     @id @default(autoincrement())
  email  String  @unique
  nome   String?
  senha  String
  tokens Token[]

  @@map("usuario")
}

model Evento {
  id          Int      @id @default(autoincrement())
  tipo_evento String
  lotacao     Int
  descricao   String
  data_evento DateTime

  @@map("evento")
}

enum Tipo_token {
  ACESSO
  REFRESH
}

model Token {
  id        Int        @id @default(autoincrement())
  token     String     @db.VarChar(255)
  tipo      Tipo_token @default(ACESSO)
  revogado  Boolean    @default(false)
  expira_em DateTime
  usuarioId Int
  usuario   Usuario    @relation(fields: [usuarioId], references: [id])

  @@map("token")
}
